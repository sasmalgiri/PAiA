# PAiA license server — environment variables
#
# Copy this to /etc/paia-license/.env on the server, fill in the real
# values, and chmod 600 it. NEVER commit the real version to git.

# ── required ───────────────────────────────────────────────────

# Listen port (the nginx config proxies from :443 → :8787)
PORT=8787

# Base64-encoded raw 32-byte Ed25519 private key. Generate ONCE with:
#   node scripts/issue-license.mjs --gen-keys
# then paste the contents of .keys/private.b64 here.
#
# CRITICAL: this key signs every license. Compromise = anyone can
# issue valid licenses. Treat it like a root CA private key:
# - Never commit to git
# - Never log
# - Never email
# - Backup in your password manager
PAIA_PRIVATE_KEY_B64=

# ── webhook secrets (set the ones you actually use) ───────────

# Stripe — from dashboard.stripe.com → Developers → Webhooks → "Signing secret"
STRIPE_WEBHOOK_SECRET=

# LemonSqueezy — from app.lemonsqueezy.com → Settings → Webhooks → your webhook
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── email delivery (pick one) ─────────────────────────────────

# Option A — Resend HTTP API (recommended)
RESEND_API_KEY=
RESEND_FROM=hello@paia.app

# Option B — SMTP fallback (only used if RESEND_API_KEY is not set)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=
# SMTP_FROM=hello@paia.app
