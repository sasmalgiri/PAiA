<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PAiA.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PAiA — Your Screen Assistant">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- ═══ ROW 0: TOP BAR ═══ -->
        <Grid Padding="16,10" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">

            <Button x:Name="CaptureBtn" Style="{ThemeResource AccentButtonStyle}" Click="Capture_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE722;" FontSize="16"/>
                    <TextBlock Text="Capture Screen"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        Margin="16,0,0,0" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="Gray"/>
                <TextBlock x:Name="StatusLabel" Text="Starting…" FontSize="12" Foreground="Gray"/>
            </StackPanel>

            <ComboBox x:Name="ModelPicker" Grid.Column="2" PlaceholderText="Model"
                      MinWidth="160" SelectionChanged="ModelPicker_Changed"/>

            <Button Grid.Column="3" Margin="8,0,0,0" Click="History_Click"
                    ToolTipService.ToolTip="Search past responses">
                <FontIcon Glyph="&#xE81C;" FontSize="14"/>
            </Button>

            <Button Grid.Column="4" Margin="4,0,0,0" Click="SecurityLab_Click"
                    ToolTipService.ToolTip="Security dashboard">
                <FontIcon Glyph="&#xE72E;" FontSize="14"/>
            </Button>

            <Button Grid.Column="5" Margin="4,0,0,0" Click="AuditLog_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE7BC;" FontSize="14"/>
                    <TextBlock x:Name="LogCountLabel" Text="Logs" FontSize="12"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="6" Margin="4,0,0,0" Click="Settings_Click">
                <FontIcon Glyph="&#xE713;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- ═══ ROW 1: CONTEXT BAR ═══ -->
        <Grid x:Name="ContextBar" Grid.Row="1" Padding="16,10" Visibility="Collapsed"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon x:Name="ContextIcon" Glyph="&#xE946;" FontSize="18"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <TextBlock x:Name="ContextTypeLabel" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ContextAppLabel" Foreground="Gray" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="RedactionCountLabel" Foreground="OrangeRed" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="RedactionDiffLabel" Grid.Row="1" FontSize="11"
                           Margin="0,4,0,0" Foreground="Gray" Visibility="Collapsed"/>
                <StackPanel x:Name="QuickActionsPanel" Grid.Row="2" Orientation="Horizontal"
                            Spacing="6" Margin="0,8,0,0"/>
            </Grid>
        </Grid>

        <!-- ═══ ROW 2: CHAT ═══ -->
        <Grid Grid.Row="2">
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE8B7;" FontSize="48" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="PAiA — Your All-Purpose Screen Assistant"
                           FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Capture any screen to get started."
                           Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="HotkeyHint" Text="" Foreground="Gray" FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>
            <ScrollViewer x:Name="ChatScroller" VerticalScrollBarVisibility="Auto" Padding="16,8">
                <StackPanel x:Name="ChatPanel" Spacing="8"/>
            </ScrollViewer>
        </Grid>

        <!-- ═══ ROW 3: INPUT BAR ═══ -->
        <Grid Grid.Row="3" Padding="16,10" ColumnDefinitions="*,Auto,Auto,Auto"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <TextBox x:Name="InputBox" PlaceholderText="Ask PAiA anything about your screen…"
                     AcceptsReturn="False" KeyDown="InputBox_KeyDown"/>
            <Button x:Name="SendBtn" Grid.Column="1" Margin="8,0,0,0"
                    Style="{ThemeResource AccentButtonStyle}" Click="Send_Click" IsEnabled="False">
                <FontIcon Glyph="&#xE724;" FontSize="16"/>
            </Button>
            <Button x:Name="PinBtn" Grid.Column="2" Margin="4,0,0,0"
                    Click="Pin_Click" IsEnabled="False" ToolTipService.ToolTip="Pin response (always on top)">
                <FontIcon Glyph="&#xE718;" FontSize="14"/>
            </Button>
            <Button Grid.Column="3" Margin="4,0,0,0" Click="NewChat_Click"
                    ToolTipService.ToolTip="New conversation">
                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- ═══ ROW 4: PRIVACY PULSE BAR ═══ -->
        <StackPanel x:Name="PrivacyPulseBar" Grid.Row="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"/>
    </Grid>
</Window>
