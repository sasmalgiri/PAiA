<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PAiA.WinUI.FormHelperOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PAiA — Form Helper"
    Width="420" Height="600">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*,Auto"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <StackPanel Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE8A5;" FontSize="20" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
            <TextBlock Text="Form Helper" Style="{ThemeResource SubtitleTextBlockStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0" Padding="12,8" CornerRadius="6"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Text="Analyzing form…"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
            <ProgressRing x:Name="Spinner" Grid.Column="1" IsActive="True" Width="20" Height="20"/>
        </Grid>

        <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FieldsPanel" Spacing="8"/>
        </ScrollViewer>

        <Grid Grid.Row="3" Margin="0,12,0,0" ColumnDefinitions="*,Auto,Auto">
            <TextBlock x:Name="CopiedCountText" Text="" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="12"/>
            <Button x:Name="CopyAllBtn" Grid.Column="1" Click="CopyAll_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                    <TextBlock Text="Copy All"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Margin="8,0,0,0" Click="Close_Click">
                <TextBlock Text="Close"/>
            </Button>
        </Grid>
    </Grid>
</Window>
